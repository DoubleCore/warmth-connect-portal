# ========== Warmth Connect Portal 配置 ==========

# 服务端口
PORT=8787

# SQLite 数据库
DATABASE_URL=./data/app.db

# PDF 存储
PDF_STORAGE_DIR=./storage/pdfs

# 前端地址 (CORS)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ========== Agent Runtime ==========
# Agent 引擎地址（自动启动，无需修改）
FASTCLAW_BASE_URL=http://127.0.0.1:18953
FASTCLAW_TIMEOUT_MS=180000

# Agent 鉴权 token（留空则不鉴权）
FASTCLAW_API_KEY=

# ========== FastClaw Agent ID 配置 ==========
# 按用途指定 FastClaw Agent。每个值都必须是 fastclaw 实例里真实存在的 agent ID
# （形如 agt_xxxxxxxxxxxxxx），从 http://127.0.0.1:18953 的控制台或
# `fastclaw agents ls` 拿到；务必不要留 `default` 之类占位符。
#
# 留空时的回退路径：
#   1. /api/fastclaw/chat 等带 agentRole 的接口取不到对应 ID → 走 client fallback
#   2. client fallback 取 FASTCLAW_AGENT_ID
#   3. 还为空就把 model 字段写成字符串 "default"
#   4. FastClaw 端 AgentByID("default") 返回 nil → 静默 fallback 到 DefaultAgent
# 这意味着随便留空都可能"看起来能跑、其实打到错的 agent"，所以必填并审查正确。
#
# 通过 docs/fastclaw-agents/setup-agents.bat 一键创建后，把脚本输出的三个 ID 抄到这里。
FASTCLAW_AGENT_ID=
FASTCLAW_AGENT_DEPLOY=
FASTCLAW_AGENT_PAPER_ANALYSE=
FASTCLAW_AGENT_RESEARCHER=

# ========== LLM Provider ==========
# Agent 使用的 LLM API（必填）
AGENT_API_KEY=sk-your-openai-key-here
AGENT_API_BASE=https://api.openai.com/v1
AGENT_MODEL=openai/gpt-4o-mini

# ========== RAG LLM ==========
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-key
LLM_CHAT_MODEL=gpt-4o-mini
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_TIMEOUT_MS=60000

# ========== Host Tracking ==========
# 主机凭证加密密钥 (32字节 hex)
HOST_CRED_KEY=
HOST_TRACKING_ENABLED=false
