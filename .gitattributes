# Normalize all text files to LF in the repository.
# Windows users will still see LF on checkout (no auto-conversion).
* text=auto eol=lf

# Binary files — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.svg binary
*.pdf binary
*.db binary
*.db-shm binary
*.db-wal binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
