# 服务端口
PORT=8787

# SQLite 数据库文件路径（相对 backend 根目录）
DATABASE_URL=./data/app.db

# PDF 本地存储目录
PDF_STORAGE_DIR=./storage/pdfs

# 允许的前端来源（CORS），多个用逗号分隔
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080

# 日志级别：fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# 环境
NODE_ENV=development

# ========== Hermes Agent 同机 HTTP 直连 ==========
# 详见 Hermes_Command_Center_HTTP_直连可用版.md
# Backend 通过 Hermes 官方 API Server 的 Runs API 调用 Agent。
#
# 在 ~/.hermes/.env 里需要启用：
#   API_SERVER_ENABLED=true
#   API_SERVER_HOST=127.0.0.1
#   API_SERVER_PORT=8642
#   API_SERVER_KEY=<与下方 HERMES_API_KEY 相同的值>
# 改完执行 `hermes gateway restart` 让新 env 生效，然后 `curl http://127.0.0.1:8642/health` 验证。
HERMES_BASE_URL=http://127.0.0.1:8642
# 单次 Hermes HTTP 控制面调用的超时（毫秒）。SSE 事件流会在握手成功后解绑超时，
# 不受此值影响。
HERMES_TIMEOUT_MS=120000
# 对应 Hermes 侧的 API_SERVER_KEY。API Server 启用后是必填项。
HERMES_API_KEY=change-me-local-dev

# ========== RAG LLM / Embedding ==========
# 详见 Design_SQLite_Abstract_RAG.md §7 / §9 / §11
# 任意 OpenAI 兼容后端（OpenAI / DeepSeek / 本地 ollama / 阿里云 DashScope 兼容模式 ...）
#
# 若 LLM_API_KEY 留空，POST /api/rag/query 会返回 503 LLM_NOT_CONFIGURED，
# 录入论文时也会跳过 embedding 生成。GET /api/rag/search（FTS5 关键词）不受影响。
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_CHAT_MODEL=gpt-4o-mini
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_TIMEOUT_MS=60000

# ========== Host Tracking（主机状态追踪）==========
# 详见 src/modules/host-tracking/
# 后端通过 SSH 每分钟采集一次主机的 GPU/CPU/内存/磁盘 状态，
# 写入 host_metrics_snapshot 表，前端面板查询历史与实时数据。
#
# 主机 SSH 密码加密密钥（必填，否则不能创建带密码的主机）。
# 生成新密钥：
#   npm run host:keygen
# 输出 64 字符 hex，粘贴到这里即可。一旦生成不要更改，否则历史密码全部解密失败。
HOST_CRED_KEY=
# 采集调度 cron（默认每分钟）。disabled 关闭。
HOST_TRACKING_CRON=* * * * *
# 连续失败几次后进入退避（5 分钟一次）
HOST_TRACKING_BACKOFF_THRESHOLD=3
HOST_TRACKING_BACKOFF_MS=300000
# 单次采集总超时
HOST_TRACKING_PROBE_TIMEOUT_MS=15000
# 服务启动时是否自动开启调度
HOST_TRACKING_ENABLED=true

# ========== FastClaw Agent（轻量对话通道） ==========
# 详见 fastclaw/ARCHITECTURE.md
# FastClaw 暴露 OpenAI 兼容的 /v1/chat/completions 接口。
# 定位：轻量对话通道，不走 Hermes 的重型编排/审批流程。
FASTCLAW_BASE_URL=http://127.0.0.1:18953
# FastClaw 的 API Key（在 FastClaw Web UI → Settings 中生成）
FASTCLAW_API_KEY=
# 连接超时（毫秒）
FASTCLAW_TIMEOUT_MS=90000
# ---------- Agent ID 配置 ----------
# 每个值都要是 fastclaw 实例里真实存在的 agent ID（agt_xxxxxxxxxxxxxx），
# 从 http://127.0.0.1:18953 控制台或 `fastclaw agents ls` 拿到。
# 留空也能跑，但 FastClaw 会静默 fallback 到 DefaultAgent —— 调用方完全不知道
# 自己其实打到了错的 agent，请务必审核确认填正确：
#   - FASTCLAW_AGENT_ID         默认对话 agent；前端如果没指定 agentRole 时用它
#   - FASTCLAW_AGENT_DEPLOY     论文部署官（manager 页面、/api/fastclaw/deploy/stream 都锁定它）
#   - FASTCLAW_AGENT_PAPER_ANALYSE  论文分析官
#   - FASTCLAW_AGENT_RESEARCHER     论文搜索官
# 一键创建参考：backend/docs/fastclaw-agents/setup-agents.bat
FASTCLAW_AGENT_ID=
FASTCLAW_AGENT_DEPLOY=
FASTCLAW_AGENT_PAPER_ANALYSE=
FASTCLAW_AGENT_RESEARCHER=
