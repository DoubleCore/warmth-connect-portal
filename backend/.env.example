# 服务端口
PORT=8787

# SQLite 数据库文件路径（相对 backend 根目录）
DATABASE_URL=./data/app.db

# PDF 本地存储目录
PDF_STORAGE_DIR=./storage/pdfs

# 允许的前端来源（CORS），多个用逗号分隔
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# 日志级别：fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# 环境
NODE_ENV=development

# ========== Hermes Agent 同机 HTTP 直连 ==========
# 详见 Hermes_Command_Center_HTTP_直连可用版.md
# Backend 通过 Hermes 官方 API Server 的 Runs API 调用 Agent。
#
# 在 ~/.hermes/.env 里需要启用：
#   API_SERVER_ENABLED=true
#   API_SERVER_HOST=127.0.0.1
#   API_SERVER_PORT=8642
#   API_SERVER_KEY=<与下方 HERMES_API_KEY 相同的值>
# 改完执行 `hermes gateway restart` 让新 env 生效，然后 `curl http://127.0.0.1:8642/health` 验证。
HERMES_BASE_URL=http://127.0.0.1:8642
# 单次 Hermes HTTP 控制面调用的超时（毫秒）。SSE 事件流会在握手成功后解绑超时，
# 不受此值影响。
HERMES_TIMEOUT_MS=120000
# 对应 Hermes 侧的 API_SERVER_KEY。API Server 启用后是必填项。
HERMES_API_KEY=change-me-local-dev
